# Telegram Bot Token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Groq API Key — get from https://console.groq.com/keys (required for Whisper STT)
GROQ_API_KEY=

# Hugging Face API Key — get from https://huggingface.co/settings/tokens (required for TTS)
HUGGINGFACE_API_KEY=

# Google AI API Key — get from https://aistudio.google.com/
GOOGLE_API_KEY=

# OpenRouter API Key — get from https://openrouter.ai/
OPENROUTER_API_KEY=

# Tavily API Key — get from https://tavily.com/ (required for high-quality web search)
TAVILY_API_KEY=

# Comma-separated Telegram user IDs allowed to use this bot
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# Max agent loop iterations (safety limit)
MAX_AGENT_ITERATIONS=10
